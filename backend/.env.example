# Copy to .env and fill in values as needed.

# Regulatory CSV/Excel bundle: default is repo ``data/`` (or REGULATORY_DATA_DIR).
# In AWS, deploy workflow syncs ``data/`` to S3; backend reads via IRSA when set:
# DATA_S3_BUCKET=<ProjectName>-<Environment>-runtime-data-<12-digit-AWS-account-id>
#   e.g. lotor-regulatory-assistant-dev-runtime-data-123456789012 (from platform stack output)
# DATA_S3_PREFIX=regulatory-app-data
# Verify S3 + prefix + IAM (use a venv with backend deps — needs boto3):
#   pip install -r requirements.txt
#   export DATA_S3_BUCKET=... DATA_S3_PREFIX=regulatory-app-data AWS_REGION=us-east-2
#   PYTHONPATH=. pytest test_regulatory_s3_smoke.py -v
# REGULATORY_DATA_DIR=/path/to/data   # optional local override
# AWS_REGION=us-east-2
# AWS_ENDPOINT_URL_S3=   # optional (e.g. LocalStack)

# LLM — default is Anthropic (see config.py LLM_PROVIDER).
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (optional; LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
# OPENAI_BASE_URL=

# Model context + token budgeting (optional; 0 = infer from provider + model id)
# LLM_CONTEXT_WINDOW_TOKENS=0
# SYNTHESIS_INPUT_OVERHEAD_TOKENS=8192
# TIKTOKEN_ENCODING=auto
# TOKEN_COUNT_METHOD=tiktoken

# Azure OpenAI
# LLM_PROVIDER=azure_openai
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT_NAME=

# Run real-network smoke tests for OpenAlex, Crossref, NIH, etc.:
#   LIVE_API_AGENTS_INTEGRATION=1 pytest test_live_api_agents.py -m live_api -v
# Same flag enables live tests through DynamicReasoningEngine:
#   LIVE_API_AGENTS_INTEGRATION=1 pytest test_dynamic_reasoning_live_api_agents.py -m live_api -v
# Stubbed engine wiring (fast, no HTTP):
#   pytest test_dynamic_reasoning_live_api_agents.py -m "not live_api" -v

# AACT Postgres (optional; set username + password from CTTI)
# AACT_DB_USERNAME=
# AACT_DB_PASSWORD=
# AACT_DB_HOST=aact-db.ctti-clinicaltrials.org
# AACT_DB_SSL=true
# If you see CERTIFICATE_VERIFY_FAILED / certificate has expired: the *server* leaf cert
# on AACT_DB_HOST may be expired (openssl: s_client -connect HOST:5432 -starttls postgres).
# PEM bundle if verify fails for other reasons (corp MITM / custom CA)
# AACT_DB_SSL_CAFILE=

# ClinicalTrials.gov API v2 (optional; default UA is set in code)
# CLINICAL_TRIALS_USER_AGENT=YourOrg/1.0 (+https://your.site/contact; research)
# CLINICAL_TRIALS_API_BASE=https://clinicaltrials.gov/api/v2

# Live API agents (optional overrides)
# NIH_REPORTER_BASE_URL=https://api.reporter.nih.gov
# NPI_REGISTRY_BASE_URL=https://npiregistry.cms.hhs.gov/api
# OPENALEX_BASE_URL=https://api.openalex.org
# OPENALEX_API_KEY=
# CROSSREF_BASE_URL=https://api.crossref.org
# CROSSREF_MAILTO=your-email@example.com
# ROR_API_BASE_URL=https://api.ror.org
# OPEN_PAYMENTS_BASE_URL=https://openpaymentsdata.cms.gov
# OPEN_PAYMENTS_DATASTORE_RESOURCE_IDS=
# EU_CTIS_SEARCH_URL=https://euclinicaltrials.eu/ctis-public-api/search
# EU_CTIS_RETRIEVE_PREFIX=https://euclinicaltrials.eu/ctis-public-api/retrieve
# ISRCTN_API_BASE_URL=https://www.isrctn.com
# CMS_DATA_API_BASE_URL=https://data.cms.gov
# FDA_DATADASHBOARD_BASE_URL=https://api-datadashboard.fda.gov/v1
# FDA_DATADASHBOARD_USER=
# FDA_DATADASHBOARD_KEY=

# Chat persistence (Postgres / RDS) — set via DATABASE_URL or REGULATORY_DATABASE_URL
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# CHAT_PERSISTENCE_ENABLED=true
# For AWS RDS (*.rds.amazonaws.com), TLS uses connect_args ssl=require (do not put sslmode= on URL for asyncpg/SQLAlchemy).
# Set CHAT_DB_SSL=false only for local Postgres without TLS.
#
# Deep research (brief/outline, verifier + replan, optional parallel sub-runs)
# DEEP_RESEARCH_ENABLED=true
# Default chat graph caps when the request sends deep_research=false (UI toggle off):
# GRAPH_PLAN_COMPACT_MAX_NODES=5
# GRAPH_PLAN_COMPACT_MAX_SEARCH_NODES=3
# Full graph ceiling when deep_research=true (or server default on):
# GRAPH_PLAN_MAX_NODES=40
# DEEP_RESEARCH_MAX_REPLANS=2
# DEEP_RESEARCH_MAX_NEW_NODES_PER_ROUND=4
# DEEP_RESEARCH_PARALLEL_SUBRUNS=true
# DEEP_RESEARCH_MIN_OUTLINE_SECTIONS_FOR_PARALLEL=4
